@model List<string>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Fashion Store";

    // التأكد من وجود صورتين على الأقل، وإلا استخدام صور افتراضية
    var images = Model != null && Model.Count >= 2
        ? Model
        : new List<string> { "~/Files/Images/lipstick.png", "~/Files/Images/powder.png" };
}

@section Styles {
    <style>
        /* -------------------- الألوان والأساسيات -------------------- */
        .full-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background-color: #000; /* خلفية سوداء */
            overflow-x: hidden;
            padding: 20px 0;
        }

        .hero-title {
            font-weight: 800;
            line-height: 0.9;
            letter-spacing: -2px;
            text-transform: uppercase;
            font-family: 'Playfair Display', serif;
            color: #fff;
            font-size: clamp(3rem, 8vw, 5.5rem);
        }

        .pink-text {
            color: #df9191;
            font-weight: 300;
        }

        .tagline {
            color: #df9191;
            font-style: italic;
            font-size: 1.2rem;
            margin-top: 15px;
            font-family: 'Playfair Display', serif;
        }

        .description {
            color: #aaa;
            max-width: 450px;
            margin-top: 20px;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .btn-view {
            background-color: #d68a8a;
            border: none;
            color: white;
            padding: 12px 40px;
            border-radius: 30px;
            font-weight: 500;
            margin-top: 30px;
            transition: 0.4s ease;
            position: relative;
            overflow: hidden;
            z-index: 1;
            display: inline-block;
            text-decoration: none;
        }

            .btn-view:before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                transition: 0.5s;
                z-index: -1;
            }

            .btn-view:hover {
                background-color: #c27676;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.3);
                color: white;
            }

                .btn-view:hover:before {
                    left: 100%;
                }

        /* -------------------- حاوية الصور -------------------- */
        .visuals-area {
            position: relative;
            height: 500px; /* ارتفاع ثابت لمنطقة الصور */
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .floating-product {
            position: absolute;
            filter: drop-shadow(0 15px 35px rgba(0,0,0,0.8));
            transition: opacity 1s ease-in-out;
            object-fit: cover;
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 15px;
        }

        /* -------------------- تحسينات الموبايل (أقل من 992px) - بحجم أكبر وأوضح -------------------- */
        @@media (max-width: 991px) {
            .full-page

        {
            padding: 20px 10px;
        }

        .row {
            flex-direction: row;
            align-items: center;
        }

        .col-lg-6 {
            flex: 0 0 50%;
            max-width: 50%;
        }

        .visuals-area {
            height: 400px; /* زيادة ارتفاع منطقة الصور */
        }

        .content-wrapper {
            text-align: right;
            padding-right: 15px;
        }

        /* تكبير حجم الخطوط */
        .hero-title {
            font-size: 3.2rem; /* أكبر من السابق */
        }

        .tagline {
            font-size: 1.4rem;
            margin-top: 15px;
        }

        .description {
            font-size: 1rem;
            max-width: 100%;
            margin-left: auto;
            margin-right: 0;
            line-height: 1.5;
        }

        .btn-view {
            padding: 10px 35px;
            font-size: 1rem;
            margin-top: 25px;
        }

        /* تكبير الصور قليلاً وتعديل مواضعها لمنع التداخل */
        .img-main {
            width: 85%; /* أكبر من 75% */
            left: 0;
            top: 5%;
            z-index: 5;
        }

        .img-secondary {
            width: 70%; /* أكبر من 60% */
            right: 0;
            bottom: 5%;
            z-index: 4;
        }

        }

        /* للشاشات الصغيرة جداً (أقل من 768px) */
        @@media (max-width: 768px) {
            .col-lg-6

        {
            flex: 0 0 40%;
            max-width: 40%;
        }

        .visuals-area {
            height: 350px;
        }

        .hero-title {
            font-size: 2.8rem;
        }

        .tagline {
            font-size: 1.2rem;
        }

        .description {
            font-size: 0.9rem;
        }

        .btn-view {
            padding: 8px 30px;
            font-size: 0.9rem;
        }

        .img-main {
            width: 90%;
            left: -5%;
            top: 5%;
        }

        .img-secondary {
            width: 75%;
            right: -5%;
            bottom: 5%;
        }

        }

        @@media (max-width: 576px) {
            .col-lg-6

        {
            flex: 0 0 35%;
            max-width: 35%;
        }

        .visuals-area {
            height: 300px;
        }

        .hero-title {
            font-size: 2.4rem;
        }

        .tagline {
            font-size: 1rem;
            margin-top: 10px;
        }

        .description {
            font-size: 0.8rem;
            margin-top: 15px;
        }

        .btn-view {
            padding: 6px 25px;
            font-size: 0.8rem;
            margin-top: 20px;
        }

        }

        @@media (max-width: 400px) {
            .col-lg-6

        {
            flex: 0 0 30%;
            max-width: 30%;
        }

        .visuals-area {
            height: 250px;
        }

        .hero-title {
            font-size: 2rem;
        }

        .description {
            font-size: 0.7rem;
        }

        .btn-view {
            padding: 5px 20px;
            font-size: 0.7rem;
        }

        }

        /* -------------------- تعديلات الشاشات الكبيرة (Desktop) -------------------- */
        @@media (min-width: 992px) {
            .visuals-area

        {
            height: 600px;
        }

        /* تحديد أحجام الصور ثابتة بالبكسل */
        .img-main {
            width: 320px;
            height: 400px;
            left: 10%;
            top: 5%;
            z-index: 5;
            transform: rotate(-5deg);
        }

        .img-secondary {
            width: 280px;
            height: 350px;
            right: 5%;
            bottom: 10%;
            z-index: 4;
            transform: rotate(5deg);
        }

        .content-wrapper {
            text-align: left;
            padding-left: 20px;
        }

        .hero-title {
            font-size: 5.5rem;
            display: block;
        }

        .description {
            font-size: 1.1rem;
            max-width: 500px;
        }

        .btn-view {
            padding: 14px 50px;
            font-size: 1.2rem;
            margin-top: 40px;
        }

        }

        /* شاشات كبيرة جداً (1400px فأكثر) */
        @@media (min-width: 1400px) {
            .container

        {
            max-width: 1400px;
        }

        .img-main {
            width: 350px;
            height: 430px;
            left: 15%;
        }

        .img-secondary {
            width: 300px;
            height: 380px;
            right: 10%;
        }

        .content-wrapper {
            padding-left: 3rem;
        }

        .hero-title {
            font-size: 6rem;
        }

        }
    </style>
}

<div class="container-fluid full-page">
    <div class="container">
        <div class="row align-items-center">
            <!-- الصور على اليسار -->
            <div class="col-lg-6 col-6 visuals-area">
                <img id="mainImage" src="" class="floating-product img-main" alt="Fashion item">
                <img id="secondaryImage" src="" class="floating-product img-secondary" alt="Fashion accessory">
            </div>

            <!-- النص على اليمين -->
            <div class="col-lg-6 col-6">
                <div class="content-wrapper">
                    <h1 class="hero-title m-0">FASHION</h1>
                    <h1 class="hero-title m-0">STORE</h1>
                    <h1 class="hero-title pink-text m-0">TRENDS</h1>
                    <p class="tagline">style & comfort</p>
                    <p class="description">
                        Discover the latest fashion trends with our exclusive collection of stylish clothing
                        designed for your unique look. Enjoy top quality and modern designs.
                    </p>

                    <a asp-controller="Products"
                       asp-action="GetAllProducts"
                       class="btn btn-view">
                        Shop Now
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // قائمة الصور من الـ Model
        const imageList = @Html.Raw(Json.Serialize(images));

        // التأكد من وجود صورتين على الأقل
        while (imageList.length < 2) {
            imageList.push(imageList[0]);
        }

        const mainImg = document.getElementById('mainImage');
        const secondaryImg = document.getElementById('secondaryImage');

        // دالة لاختيار صورتين عشوائيتين مختلفتين
        function getRandomTwoImages() {
            if (imageList.length === 1) {
                return [imageList[0], imageList[0]];
            }
            let firstIndex = Math.floor(Math.random() * imageList.length);
            let secondIndex;
            do {
                secondIndex = Math.floor(Math.random() * imageList.length);
            } while (secondIndex === firstIndex && imageList.length > 1);
            return [imageList[firstIndex], imageList[secondIndex]];
        }

        // دالة تغيير الصور مع تأثير Fade
        function swapImages() {
            const [src1, src2] = getRandomTwoImages();

            mainImg.style.opacity = '0';
            secondaryImg.style.opacity = '0';

            setTimeout(() => {
                // إزالة ~/ من مسار الصور إذا لزم الأمر
                mainImg.src = src1.replace('~/', '/');
                secondaryImg.src = src2.replace('~/', '/');
                mainImg.style.opacity = '1';
                secondaryImg.style.opacity = '1';
            }, 500);
        }

        // تعيين الصور الأولية
        (function initImages() {
            const [src1, src2] = getRandomTwoImages();
            mainImg.src = src1.replace('~/', '/');
            secondaryImg.src = src2.replace('~/', '/');
            mainImg.style.opacity = '1';
            secondaryImg.style.opacity = '1';
        })();

        // تغيير الصور كل 4 ثواني
        setInterval(swapImages, 4000);
    </script>
}